<Window x:Class="SETSDeployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SETSDeployer.Converters"
        xmlns:vm="clr-namespace:SETSDeployer.ViewModels"
        Title="SETS Deployer" Height="900" Width="860"
        MinHeight="700" MinWidth="700"
        Background="{StaticResource Brush_BG0}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter          x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>
        <conv:StatusToBrushConverter             x:Key="StatusToBrush"/>
        <conv:StatusToLabelConverter             x:Key="StatusToLabel"/>
        <conv:ConnStatusToBrushConverter         x:Key="ConnToBrush"/>
        <conv:ConnStatusToLabelConverter         x:Key="ConnToLabel"/>
        <conv:CheckedToBgConverter               x:Key="CheckedToBg"/>
    </Window.Resources>

    <DockPanel>

        <!-- ── Title Bar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Brush_BG1}"
                BorderBrush="{StaticResource Brush_Border}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid Height="54">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SETS Deployer"
                               FontFamily="Segoe UI Semibold" FontSize="15"
                               Foreground="{StaticResource Brush_Text1}"/>
                    <TextBlock Text="v1.0"
                               FontSize="11" Margin="10,0,0,0"
                               Foreground="{StaticResource Brush_Text3}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Tab Control ────────────────────────────────────────────────── -->
        <TabControl>

            <!-- ══════════════════ DEPLOY TAB ══════════════════ -->
            <TabItem Header="Deploy">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource Brush_BG0}">
                    <StackPanel Margin="16" HorizontalAlignment="Stretch">

                        <!-- Build Options -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="BUILD OPTIONS" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Frontend pill -->
                                    <Border Grid.Column="0" Background="{StaticResource Brush_BG3}"
                                            CornerRadius="6" Padding="14,10"
                                            Cursor="Hand" MouseLeftButtonUp="FeOption_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkFrontend" Grid.Column="0"
                                                      IsChecked="{Binding BuildFrontend}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Frontend" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="npm run build" FontSize="11"
                                                           Foreground="{StaticResource Brush_Text2}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Backend pill -->
                                    <Border Grid.Column="2" Background="{StaticResource Brush_BG3}"
                                            CornerRadius="6" Padding="14,10"
                                            Cursor="Hand" MouseLeftButtonUp="BeOption_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkBackend" Grid.Column="0"
                                                      IsChecked="{Binding BuildBackend}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Backend" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="dotnet publish" FontSize="11"
                                                           Foreground="{StaticResource Brush_Text2}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Target Branches -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" MinHeight="240">
                            <DockPanel>
                                <!-- Header -->
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="TARGET BRANCHES" Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" Margin="0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Select All" Style="{StaticResource LinkButton}"
                                                Margin="0,0,12,0" Click="SelectAll_Click"/>
                                        <Button Content="Clear All" Style="{StaticResource LinkButton}"
                                                Click="ClearAll_Click"/>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Branch rows -->
                                <ItemsControl ItemsSource="{Binding Branches}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,4" CornerRadius="5" Padding="12,10"
                                                    Background="{Binding IsChecked, Converter={StaticResource CheckedToBg}}"
                                                    BorderBrush="{StaticResource Brush_Border}"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="BranchRow_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding UncPath}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource Brush_Text2}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Status dot -->
                                                    <Ellipse Grid.Column="3" Width="8" Height="8"
                                                             Margin="12,0,6,0" VerticalAlignment="Center"
                                                             Fill="{Binding DeployStatus, Converter={StaticResource StatusToBrush}}"/>
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding DeployStatus, Converter={StaticResource StatusToLabel}}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               Foreground="{Binding DeployStatus, Converter={StaticResource StatusToBrush}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <!-- Progress -->
                        <ProgressBar Value="{Binding Progress}" Maximum="100"
                                     Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{StaticResource Brush_Text3}"
                                   Margin="0,0,0,10"/>

                        <!-- Deploy / Cancel button -->
                        <Button Content="🚀   Deploy Selected"
                                Style="{StaticResource PrimaryButton}"
                                Height="46" Margin="0,0,0,4"
                                IsEnabled="{Binding IsNotDeploying}"
                                Visibility="{Binding IsNotDeploying, Converter={StaticResource BoolToVis}}"
                                Click="Deploy_Click"/>
                        <Button Content="✕   Cancel Deployment"
                                Style="{StaticResource DangerButton}"
                                Height="46" Margin="0,0,0,4"
                                Visibility="{Binding IsDeploying, Converter={StaticResource BoolToVis}}"
                                Click="Cancel_Click"/>

                        <!-- Log -->
                        <Border Style="{StaticResource Card}" Margin="0,10,0,0" Height="240">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="BUILD &amp; DEPLOY LOG" Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" Margin="0"/>
                                    <Button Content="Clear" Style="{StaticResource LinkButton}"
                                            HorizontalAlignment="Right" Click="ClearLog_Click"/>
                                </DockPanel>
                                <Border Background="{StaticResource Brush_LogBg}" CornerRadius="4">
                                    <ScrollViewer x:Name="LogScrollViewer"
                                                  VerticalScrollBarVisibility="Auto">
                                        <RichTextBox x:Name="LogBox"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     IsReadOnly="True"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     Foreground="{StaticResource Brush_Text2}"
                                                     Padding="10,8"
                                                     IsDocumentEnabled="True"/>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>

                        <!-- Maintenance -->
                        <Border Style="{StaticResource Card}" Margin="0,10,0,0">
                            <StackPanel>
                                <!-- Header -->
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="MAINTENANCE MODE" Style="{StaticResource SectionLabel}" Margin="0"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource Brush_Text2}"
                                                   Text="Puts selected branches into maintenance — users see a branded holding page instead of SETS."/>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Branch checklist -->
                                <ItemsControl x:Name="MaintBranchList" ItemsSource="{Binding Branches}" Margin="0,0,0,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,4" CornerRadius="5" Padding="10,8"
                                                    Background="{StaticResource Brush_BG2}"
                                                    BorderBrush="{StaticResource Brush_Border}"
                                                    BorderThickness="1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="MaintRow_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsMaintChecked}"
                                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding UncPath}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource Brush_Text3}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="280"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Buttons -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="🔧   Enable Maintenance"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="#7c4dff"
                                            Height="40"
                                            Click="EnableMaintenance_Click"/>
                                    <Button Grid.Column="2"
                                            Content="✓   Disable Maintenance"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource Brush_Success}"
                                            Height="40"
                                            Click="DisableMaintenance_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════ MANAGE BRANCHES TAB ══════════════════ -->
            <TabItem Header="Manage Branches">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource Brush_BG0}">
                    <StackPanel Margin="16">

                        <!-- Branch list -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" MinHeight="200">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="CONFIGURED BRANCHES" Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center" Margin="0"/>
                                    <Button Content="Test All Connections" Style="{StaticResource LinkButton}"
                                            HorizontalAlignment="Right" Click="TestAll_Click"/>
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding Branches}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,4" CornerRadius="5"
                                                    Background="{StaticResource Brush_BG3}"
                                                    BorderBrush="{StaticResource Brush_Border}"
                                                    BorderThickness="1" Padding="12,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding UncPath}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource Brush_Text2}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,12,0"/>

                                                    <!-- Connection badge -->
                                                    <Border Grid.Column="2" CornerRadius="4"
                                                            Padding="8,3" Margin="0,0,10,0"
                                                            VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{StaticResource C_BG4}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding ConnStatus, Converter={StaticResource ConnToLabel}}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{Binding ConnStatus, Converter={StaticResource ConnToBrush}}"/>
                                                    </Border>

                                                    <!-- Action buttons -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                        <Button Content="Stop"    Style="{StaticResource GhostButton}" Margin="0,0,4,0"
                                                                Tag="{Binding}" Click="IisStop_Click"/>
                                                        <Button Content="Start"   Style="{StaticResource GhostButton}" Margin="0,0,4,0"
                                                                Tag="{Binding}" Click="IisStart_Click"/>
                                                        <Button Content="Restart" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                                                Tag="{Binding}" Click="IisRestart_Click"/>
                                                        <Button Content="✕" Style="{StaticResource GhostButton}"
                                                                Foreground="{StaticResource Brush_Danger}"
                                                                Tag="{Binding}" Click="RemoveBranch_Click"
                                                                Padding="8,3"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <!-- Add Branch -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="ADD BRANCH" Style="{StaticResource SectionLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Branch Name" FontSize="11"
                                                   Foreground="{StaticResource Brush_Text2}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="UNC Path" FontSize="11"
                                                   Foreground="{StaticResource Brush_Text2}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding NewPath, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="App Pool / Site Name" FontSize="11"
                                                   Foreground="{StaticResource Brush_Text2}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding NewPool, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="+ Add Branch"
                                            Style="{StaticResource PrimaryButton}"
                                            MinHeight="34" VerticalAlignment="Bottom"
                                            Click="AddBranch_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════ SETTINGS TAB ══════════════════ -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource Brush_BG0}">
                    <StackPanel Margin="16">

                        <!-- Build Paths -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="BUILD PATHS" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Solution Root  (folder containing deploy.ps1, sets.client\, SETS.Server\)"
                                           FontSize="11" Foreground="{StaticResource Brush_Text2}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="88"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" MinHeight="34"
                                             Text="{Binding SolutionRootPath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="2" Content="Browse"
                                            Style="{StaticResource GhostButton}"
                                            Height="34" Click="BrowseSolution_Click"/>
                                </Grid>

                                <TextBlock Text="Publish Output Path  (dotnet publish target folder)"
                                           FontSize="11" Foreground="{StaticResource Brush_Text2}" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="88"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" MinHeight="34"
                                             Text="{Binding PublishOutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="2" Content="Browse"
                                            Style="{StaticResource GhostButton}"
                                            Height="34" Click="BrowsePublish_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="App Version  (patched into appsettings.json on each deploy)"
                                   FontSize="11" Foreground="{StaticResource Brush_Text2}" Margin="0,14,0,4"/>
                        <TextBox Text="{Binding AppVersion, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="34" Margin="0,0,0,0"/>

                        <TextBlock Text="Deployer Key  (must match DeployerKey in each branch appsettings.json)"
                                   FontSize="11" Foreground="{StaticResource Brush_Text2}" Margin="0,14,0,4"/>
                        <TextBox Text="{Binding DeployerKey, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="34" Margin="0,0,0,0"/>

                        <Button Content="💾   Save Settings"
                                Style="{StaticResource PrimaryButton}"
                                Height="42" Margin="0,0,0,12"
                                Click="SaveSettings_Click"/>

                        <!-- Notes -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="NOTES" Style="{StaticResource SectionLabel}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource Brush_Text2}"
                                           LineHeight="22" TextWrapping="Wrap">
                                    <Run>•  Solution Root = folder containing deploy.ps1, sets.client\ and SETS.Server\</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run>•  Publish Output = where dotnet publish writes files (e.g. &lt;root&gt;\publish)</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run>•  Branch UNC paths must be reachable from this machine before deploying.</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run>•  IIS Start/Stop/Restart uses appcmd over ADMIN$ — requires remote admin rights on each branch server.</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
